{
  // Notes about selected package.json fields.
  // This file is documentation only, not a manifest.
  "scripts": {
    // Formatting stays explicit instead of being hidden inside lint or typecheck.
    "fmt": "",
    "fmt:check": "",
    // Linting runs through Oxlint directly.
    "lint": "",
    "lint:fix": "",
    // Why not `--no-exit-on-error`:
    // - That is better for a full-sweep debugging pass.
    // - It is worse as the default when we want the fastest signal.
    "check": ""
  }
}
