{
  "languages": {
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  }
}
