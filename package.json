{
  "name": "responsibleapi",
  "type": "module",
  "scripts": {
    "check": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "test:slow": "vitest run src/",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@seriousme/openapi-schema-validator": "^2.8.0",
    "fast-deep-equal": "^3.1.3",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  },
  "x-package-json-docs": "docs/package.jsonc"
}
