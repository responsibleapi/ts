{
  "name": "responsibleapi",
  "type": "module",
  "scripts": {
    "check": "bun run --parallel typecheck lint test",
    "fmt": "bun oxfmt",
    "fmt:check": "bun oxfmt --check",
    "lint": "bun eslint src",
    "lint2": "bun oxlint src",
    "lint2:fix": "bun oxlint --fix src",
    "lint:fix": "bun eslint src --fix",
    "test": "bun test",
    "typecheck": "bun tsc"
  },
  "dependencies": {
    "@seriousme/openapi-schema-validator": "^2.8.0",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.3",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
