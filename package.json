{
  "name": "responsibleapi",
  "type": "module",
  "scripts": {
    "check": "bun run check:fast",
    "check:fast": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "fmt": "bun oxfmt",
    "fmt:check": "bun oxfmt --check",
    "lint": "bun oxlint src",
    "lint:fix": "bun oxlint --fix src",
    "test": "bun test",
    "test-dont-use": "bun vitest run src/",
    "typecheck": "bun tsc"
  },
  "dependencies": {
    "@seriousme/openapi-schema-validator": "^2.8.0",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  }
}
